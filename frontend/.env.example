# ============================================
# Sponsoring Wall - Production Environment
# ============================================
# Copy this file to .env and fill in all values!
# NEVER commit the .env file to version control!

# --- Database ---
POSTGRES_PASSWORD=          # Strong password, min 20 chars, e.g.: $(openssl rand -base64 24)

# --- JWT & Encryption ---
# JWT Secret must be at least 32 characters
PROD_JWT_SECRET=            # e.g.: $(openssl rand -base64 48)
# Encryption key for Realtime (exactly 16 bytes)
PROD_ENC_KEY=               # e.g.: $(openssl rand -hex 8)
# Secret Key Base for Realtime (min 64 chars)
PROD_SECRET_KEY_BASE=       # e.g.: $(openssl rand -base64 48)

# --- Frontend (baked into JS at build time) ---
# The public URL where Kong API Gateway is accessible
VITE_SUPABASE_URL=https://api.yourdomain.com
# Anon key - generate with your PROD_JWT_SECRET
VITE_SUPABASE_ANON_KEY=     # Generate: node generate-jwt.js

# --- Domain ---
DOMAIN=yourdomain.com
